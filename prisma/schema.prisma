generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ────────────────────────────────────────

enum UserRole {
  CUSTOMER
  BARBER
  ADMIN
}

enum BarberStatus {
  INCOMPLETE
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  ON_THE_WAY
  STARTED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  HELD
  PENDING_RELEASE
  RELEASED
  REFUNDED
  FAILED
}

enum TransactionType {
  PENDING_CREDIT
  EARNING
  PLATFORM_FEE
  PAYOUT
  INSTANT_WITHDRAWAL
  WITHDRAWAL_FEE
  WITHDRAWAL_REVERSAL
  REFUND_REVERSAL
}

enum WithdrawalStatus {
  REQUESTED
  PROCESSING
  COMPLETED
  FAILED
}

enum ReportCategory {
  SERVICE_QUALITY
  NO_SHOW
  PAYMENT
  BEHAVIOUR
  OTHER
}

enum ReportStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED_REFUNDED
  RESOLVED_NO_REFUND
  REJECTED
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// ─── USER ─────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  profilePhoto String?
  role         UserRole
  isBlocked    Boolean  @default(false)
  fcmToken     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barberProfile BarberProfile?
  bookings      Booking[]      @relation("CustomerBookings")
  reviews       Review[]
  chatMessages  ChatMessage[]

  @@index([email])
  @@index([role])
}

// ─── BARBER ───────────────────────────────────────

model BarberProfile {
  id        String       @id @default(uuid())
  userId    String       @unique
  user      User         @relation(fields: [userId], references: [id])
  bio       String?
  experience String?
  status    BarberStatus @default(INCOMPLETE)
  rejectionReason String?
  submittedAt DateTime?
  isOnline  Boolean      @default(false)
  latitude  Float?
  longitude Float?
  address   String?
  postcode  String?
  // UK bank details for manual payouts. Stored plain for MVP — if
  // compliance tightens later, migrate to application-level encryption.
  bankAccountName   String?
  bankSortCode      String?    // 6 digits, stored without dashes
  bankAccountNumber String?    // 8 digits
  termsAcceptedAt DateTime?
  termsVersion    String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  services     Service[]
  availability AvailabilitySlot[]
  settings     BarberSettings?
  wallet       Wallet?
  bookings     Booking[]      @relation("BarberBookings")
  reviews      Review[]
  photos       BarberPhoto[]

  @@index([status])
  @@index([isOnline])
  @@index([latitude, longitude])
}

model BarberPhoto {
  id              String        @id @default(uuid())
  barberProfileId String
  barberProfile   BarberProfile @relation(fields: [barberProfileId], references: [id], onDelete: Cascade)
  url             String
  storagePath     String?
  order           Int           @default(0)
  createdAt       DateTime      @default(now())

  @@index([barberProfileId])
}

model Service {
  id              String        @id @default(uuid())
  barberProfileId String
  barberProfile   BarberProfile @relation(fields: [barberProfileId], references: [id], onDelete: Cascade)
  name            String
  durationMinutes Int
  priceInPence    Int
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  bookingServices BookingService[]

  @@index([barberProfileId])
}

model AvailabilitySlot {
  id              String        @id @default(uuid())
  barberProfileId String
  barberProfile   BarberProfile @relation(fields: [barberProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       DayOfWeek
  startTime       String        // "09:00" (HH:mm)
  endTime         String        // "17:00" (HH:mm)
  isActive        Boolean       @default(true)

  @@unique([barberProfileId, dayOfWeek])
  @@index([barberProfileId])
}

model BarberSettings {
  id                    String        @id @default(uuid())
  barberProfileId       String        @unique
  barberProfile         BarberProfile @relation(fields: [barberProfileId], references: [id], onDelete: Cascade)
  serviceRadiusMiles    Float         @default(5.0)
  minBookingNoticeHours Int           @default(2)
  updatedAt             DateTime      @updatedAt
}

// ─── BOOKING ──────────────────────────────────────

model Booking {
  id           String        @id @default(uuid())
  customerId   String
  customer     User          @relation("CustomerBookings", fields: [customerId], references: [id])
  barberId     String
  barber       BarberProfile @relation("BarberBookings", fields: [barberId], references: [id])
  date         DateTime
  startTime    String        // "09:30" (HH:mm)
  status       BookingStatus @default(PENDING)
  address      String
  latitude     Float?
  longitude    Float?
  totalInPence Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  services         BookingService[]
  payment          Payment?
  verificationCode VerificationCode?
  chatRoom         ChatRoom?
  reports          Report[]

  @@index([customerId])
  @@index([barberId])
  @@index([status])
  @@index([date])
}

model BookingService {
  id           String  @id @default(uuid())
  bookingId    String
  booking      Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  serviceId    String
  service      Service @relation(fields: [serviceId], references: [id])
  priceInPence Int

  @@index([bookingId])
}

model VerificationCode {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  code      String
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── PAYMENT ──────────────────────────────────────

model Payment {
  id                    String        @id @default(uuid())
  bookingId             String        @unique
  booking               Booking       @relation(fields: [bookingId], references: [id])
  stripePaymentIntentId String        @unique
  amountInPence         Int
  platformFeeInPence    Int           @default(499)
  barberAmountInPence   Int
  status                PaymentStatus @default(HELD)
  capturedAt            DateTime?
  heldUntil             DateTime?
  releasedAt            DateTime?
  refundedAt            DateTime?
  refundReason          String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([stripePaymentIntentId])
}

// ─── WALLET ───────────────────────────────────────

model Wallet {
  id                String        @id @default(uuid())
  barberProfileId   String        @unique
  barberProfile     BarberProfile @relation(fields: [barberProfileId], references: [id])
  // Two-bucket model: captured funds sit in `pending` for 24h after the
  // verification code is entered, then move to `available` when the release
  // worker runs. Only `available` can be withdrawn.
  availableInPence  Int           @default(0)
  pendingInPence    Int           @default(0)
  updatedAt         DateTime      @updatedAt

  transactions        WalletTransaction[]
  withdrawalRequests  WithdrawalRequest[]
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  walletId      String
  wallet        Wallet           @relation(fields: [walletId], references: [id])
  amountInPence Int              // gross requested (= what leaves `available`)
  feeInPence    Int              // platform withdrawal fee (0 at MVP)
  netInPence    Int              // what actually lands in the bank
  status        WithdrawalStatus @default(REQUESTED)
  // Snapshot — frozen at request time so a barber changing their bank
  // details later doesn't repoint in-flight money.
  bankAccountName   String
  bankSortCode      String
  bankAccountNumber String
  // Admin-side bookkeeping.
  bankReference String?   // Bank transaction id / reference when marked paid.
  adminNote     String?
  processedById String?   // User.id of the admin who actioned it.
  processedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([walletId])
  @@index([status])
  @@index([createdAt])
}

model WalletTransaction {
  id            String          @id @default(uuid())
  walletId      String
  wallet        Wallet          @relation(fields: [walletId], references: [id])
  type          TransactionType
  amountInPence Int
  description   String?
  bookingId     String?
  createdAt     DateTime        @default(now())

  @@index([walletId])
  @@index([createdAt])
}

// ─── CHAT ─────────────────────────────────────────

model ChatRoom {
  id        String   @id @default(uuid())
  bookingId String   @unique
  booking   Booking  @relation(fields: [bookingId], references: [id])
  createdAt DateTime @default(now())
  // Last time each party opened the conversation. Used to compute
  // unread counts in the inbox and "Seen" markers on sent messages.
  // Null = never opened — treat every incoming message as unread.
  customerLastReadAt DateTime?
  barberLastReadAt   DateTime?

  messages ChatMessage[]
}

model ChatMessage {
  id         String   @id @default(uuid())
  chatRoomId String
  chatRoom   ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User     @relation(fields: [senderId], references: [id])
  content    String
  createdAt  DateTime @default(now())

  @@index([chatRoomId, createdAt])
}

// ─── REPORT / DISPUTE ─────────────────────────────

model Report {
  id              String         @id @default(uuid())
  bookingId       String
  booking         Booking        @relation(fields: [bookingId], references: [id])
  raisedById      String
  category        ReportCategory
  description     String
  // Set when the customer is asking for their money back — surfaces a
  // "request refund" badge in the admin disputes panel.
  requestRefund   Boolean        @default(false)
  status          ReportStatus   @default(OPEN)
  adminNote       String?
  resolvedById    String?
  resolvedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  images ReportImage[]

  @@index([bookingId])
  @@index([status])
  @@index([raisedById])
}

model ReportImage {
  id        String   @id @default(uuid())
  reportId  String
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  url       String
  createdAt DateTime @default(now())

  @@index([reportId])
}

// ─── REVIEW ───────────────────────────────────────

model Review {
  id              String        @id @default(uuid())
  customerId      String
  customer        User          @relation(fields: [customerId], references: [id])
  barberProfileId String
  barberProfile   BarberProfile @relation(fields: [barberProfileId], references: [id])
  rating          Int
  comment         String?
  createdAt       DateTime      @default(now())

  @@index([barberProfileId])
  @@index([customerId])
}
